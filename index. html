<script>
document.getElementById('year').textContent = new Date().getFullYear();

/* header shadow */
const header = document.getElementById('siteHeader');
window.addEventListener('scroll', () => {
  header.classList.toggle('scrolled', window.scrollY > 8);
  document.getElementById('toTop').classList.toggle('show', window.scrollY > 500);
});

/* mobile nav */
const navToggle = document.getElementById('navToggle');
const navLinks = document.getElementById('navLinks');
navToggle.addEventListener('click', () => navLinks.classList.toggle('open'));
navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navLinks.classList.remove('open')));

/* back to top */
document.getElementById('toTop').addEventListener('click', () => window.scrollTo({top:0,behavior:'smooth'}));

/* hero bloom animation */
if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
  document.querySelectorAll('#bloomSvg .petal').forEach((p, i) => {
    p.style.transform = 'scale(0)';
    p.style.opacity = '0';
    p.style.transition = `transform .7s cubic-bezier(.34,1.56,.64,1) ${i*0.12}s, opacity .5s ease ${i*0.12}s`;
    requestAnimationFrame(() => requestAnimationFrame(() => {
      p.style.transform = 'scale(1)';
      p.style.opacity = '1';
    }));
  });
}

/* scroll reveal */
const revealEls = document.querySelectorAll('.reveal');
const io = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
}, {threshold:0.15});
revealEls.forEach(el => io.observe(el));

/* ================= SUPABASE ================= */
const SUPABASE_URL = 'https://gchaerzotkzhlpldpjvu.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdjaGFlcnpvdGt6aGxwbGRwanZ1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2MTg1MzMsImV4cCI6MjA5OTE5NDUzM30.qPbHC0uY49F049hBvbgswOtYW2n7xaiILOWqoDEvgRI';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let whatsappNumber = '5500000000000';
const iconPetal = `<svg viewBox="0 0 100 100" fill="none"><g fill="#fff"><path d="M50 50 C50 20 35 8 50 0 C65 8 50 20 50 50 Z"/><path d="M50 50 C22 45 10 28 0 38 C6 54 26 58 50 50 Z"/><path d="M50 50 C78 45 90 28 100 38 C94 54 74 58 50 50 Z"/></g></svg>`;
const placeholderColors = ['ph-a','ph-b','ph-c'];

function applyWhatsappLinks(){
  document.querySelectorAll('.wa-link').forEach(a => { a.href = `https://wa.me/${whatsappNumber}`; });
}

/* ---- SETTINGS (whatsapp, instagram, hero texts) ---- */
async function loadSettings(){
  const { data, error } = await sb.from('settings').select('*');
  if (error || !data) return;
  const map = {}; data.forEach(s => map[s.key] = s.value);
  if (map.whatsapp_number){ whatsappNumber = map.whatsapp_number; applyWhatsappLinks(); }
  if (map.instagram_handle){
    document.querySelectorAll('.ig-link').forEach(a => { a.href = `https://instagram.com/${map.instagram_handle}`; a.textContent = a.textContent.includes('@') ? `@${map.instagram_handle}` : a.textContent; });
  }
  if (map.hero_title) document.querySelector('.hero h1').innerHTML = map.hero_title;
  if (map.hero_subtitle) document.querySelector('.hero .lead').textContent = map.hero_subtitle;
}

/* ---- CATEGORIES + PRODUCTS ---- */
let allProducts = [];
async function loadCategoriesAndProducts(){
  const { data: categories } = await sb.from('categories').select('*').order('sort_order');
  const filtersEl = document.getElementById('filters');
  if (categories && categories.length){
    filtersEl.innerHTML = '<button class="filter-btn active" data-filter="all">Todos</button>' +
      categories.map(c => `<button class="filter-btn" data-filter="${c.slug}">${c.name}</button>`).join('');
    filtersEl.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        filtersEl.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderProducts(btn.dataset.filter);
      });
    });
  }
  const { data: products, error } = await sb.from('products').select('*, categories(slug)').eq('active', true).order('sort_order');
  allProducts = (!error && products) ? products.map(p => ({
    name: p.name, desc: p.description || '', image_url: p.image_url,
    cat: p.categories ? p.categories.slug : null
  })) : [];
  renderProducts('all');
}
function renderProducts(filter){
  const grid = document.getElementById('prodGrid');
  grid.innerHTML = '';
  const list = allProducts.filter(p => filter==='all' || p.cat===filter);
  if (!list.length){
    grid.innerHTML = `<p style="grid-column:1/-1;text-align:center;color:var(--text-muted);">Em breve novos produtos por aqui — fale com a gente pelo WhatsApp!</p>`;
    return;
  }
  list.forEach((p,i) => {
    const msg = encodeURIComponent(`Olá! Gostaria de solicitar um orçamento para: ${p.name}`);
    const imgContent = p.image_url
      ? `<img src="${p.image_url}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;">`
      : `<div class="fill ${placeholderColors[i % 3]}">${iconPetal}</div>`;
    grid.insertAdjacentHTML('beforeend', `
      <div class="prod-card reveal">
        <div class="prod-img">${imgContent}</div>
        <div class="prod-body">
          <h3>${p.name}</h3>
          <p>${p.desc}</p>
          <a class="btn btn-ghost" href="https://wa.me/${whatsappNumber}?text=${msg}" target="_blank" rel="noopener">Solicitar orçamento</a>
        </div>
      </div>`);
  });
  grid.querySelectorAll('.reveal').forEach(el => io.observe(el));
}

/* ---- TESTIMONIALS ---- */
const fallbackReviews = [
  {name:'Camila Rocha', comment:'Trabalho impecável! O buquê ficou ainda mais lindo do que eu imaginava, super delicado.', stars:5},
  {name:'Fernanda Alves', comment:'Atendimento maravilhoso do início ao fim. Recomendo demais a Lotus.', stars:5},
  {name:'Juliana Prado', comment:'Presente perfeito, chegou dentro do prazo combinado e com um capricho enorme.', stars:5},
];
async function loadTestimonials(){
  const { data, error } = await sb.from('testimonials').select('*').eq('active', true).order('sort_order');
  const list = (!error && data && data.length) ? data : fallbackReviews;
  const track = document.getElementById('reviewsTrack');
  track.innerHTML = '';
  list.forEach(r => {
    track.insertAdjacentHTML('beforeend', `
      <div class="review-card reveal">
        <div class="review-top">
          <div class="avatar">${r.name.split(' ').map(w=>w[0]).slice(0,2).join('')}</div>
          <div><div class="review-name">${r.name}</div><div class="stars">${'★'.repeat(r.stars)}${'☆'.repeat(5-r.stars)}</div></div>
        </div>
        <p>${r.comment}</p>
      </div>`);
  });
  track.querySelectorAll('.reveal').forEach(el => io.observe(el));
}

/* ---- FAQ ---- */
async function loadFaqs(){
  const { data, error } = await sb.from('faqs').select('*').eq('active', true).order('sort_order');
  const faqList = document.getElementById('faqList');
  faqList.innerHTML = '';
  ((!error && data) ? data : []).forEach(f => {
    faqList.insertAdjacentHTML('beforeend', `
      <div class="faq-item">
        <button class="faq-q"><span>${f.question}</span><span class="plus">+</span></button>
        <div class="faq-a"><p>${f.answer}</p></div>
      </div>`);
  });
  faqList.querySelectorAll('.faq-item').forEach(item => {
    const q = item.querySelector('.faq-q');
    const a = item.querySelector('.faq-a');
    q.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      faqList.querySelectorAll('.faq-item').forEach(i => { i.classList.remove('open'); i.querySelector('.faq-a').style.maxHeight = null; });
      if (!isOpen){ item.classList.add('open'); a.style.maxHeight = a.scrollHeight + 'px'; }
    });
  });
}

/* CONTACT FORM -> WhatsApp */
document.getElementById('contactForm').addEventListener('submit', (e) => {
  e.preventDefault();
  const nome = document.getElementById('nome').value;
  const telefone = document.getElementById('telefone').value;
  const produto = document.getElementById('produto').value;
  const mensagem = document.getElementById('mensagem').value;
  const text = encodeURIComponent(`Olá! Meu nome é ${nome} (${telefone}).\nGostaria de um orçamento para: ${produto}.\n${mensagem}`);
  window.open(`https://wa.me/${whatsappNumber}?text=${text}`, '_blank');
});

/* INIT */
applyWhatsappLinks();
loadSettings();
loadCategoriesAndProducts();
loadTestimonials();
loadFaqs();
</script>
